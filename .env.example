# Copy to .env and fill in. All have dev-friendly defaults except in production.

# Absolute URL the browser uses to reach this app (used to build the Plex
# OAuth forwardUrl). Must match where you actually serve it. Set per
# environment — e.g. on fastapi cloud:
#   BASE_URL=https://plex-watchlist-matcher-test.fastapicloud.dev
BASE_URL=http://localhost:8000

# Both keys below are OPTIONAL: if unset, a random one is generated on startup.
# That's fine for a single ephemeral instance (the DB is wiped on restart too).
# Set fixed values when running multiple workers/replicas — every process needs
# the SAME keys (else sessions and token decryption break across processes) —
# or to keep sessions/tokens across restarts.

# Signs session cookies. Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
# SECRET_KEY=

# Encrypts Plex tokens at rest. Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# FERNET_KEY=

# Database. Locally this defaults to a SQLite file. On a multi-instance host
# (e.g. fastapi cloud) you MUST point every instance at one shared database, or
# rooms created on one instance won't exist on the others ("Room not found" on
# reload). Set DATABASE_URL to a managed Postgres URL — it takes precedence over
# DB_URL when present (Neon, Heroku, … expose exactly this name):
#   DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/db?sslmode=require
DB_URL=sqlite:///./data/app.db
DATA_DIR=./data
CACHE_DIR=./data/imgcache

# How long a comparison room (and its stored tokens) lives.
ROOM_TTL_HOURS=24

# Set to true when serving over HTTPS so cookies are marked Secure.
COOKIE_SECURE=false

# --- Deployment (docker compose) only ---
# Domain Caddy serves and auto-provisions TLS for. With a real domain, set:
#   DOMAIN=watchlist.example.com  and  BASE_URL=https://watchlist.example.com
# For plain-HTTP testing use DOMAIN=:80, BASE_URL=http://<host> and COOKIE_SECURE=false.
# (DB_URL/DATA_DIR/CACHE_DIR are overridden by docker-compose.yml to the /data volume.)
DOMAIN=watchlist.example.com
